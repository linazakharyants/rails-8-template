<style>
  .notes-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 10px;
  }

  .notes-topbar h1 {
    margin: 0;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }

  .note-row {
    display: block;
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid #ddd;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s ease;
    cursor: pointer;
  }

  .note-row:hover {
    background: #f8f7ff;
    border-color: #dcd7ff;
    transform: translateY(-1px);
  }

  .note-preview {
    font-size: 14px;
    line-height: 1.4;
  }

  .note-date {
    font-size: 12px;
    color: #888;
    margin-top: 4px;
  }

  .note-editor {
    margin-top: 12px;
    margin-bottom: 14px;
  }

  .note-editor trix-editor {
    min-height: 220px;
    border-radius: 10px;
    border: 1px solid #ddd;
    background: #fff;
    padding: 10px 12px;
  }

  .notes-section-title {
    margin-bottom: 12px;
  }

  .note-form-card {
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 14px;
    padding: 18px;
    margin-bottom: 22px;
  }

  .notes-empty {
    padding: 16px;
    border: 1px dashed #d8d8d8;
    border-radius: 12px;
    background: #fcfcfc;
    color: #777;
    font-size: 14px;
  }

  .note-hidden-content {
    display: none;
  }

  .note-preview-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.48);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.18s ease, visibility 0.18s ease;
  }

  .note-preview-modal.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .note-preview-card {
    position: relative;
    width: min(760px, 92vw);
    max-height: 85vh;
    overflow: auto;
    background: #fff;
    border: 1px solid #e9e9e9;
    border-radius: 18px;
    padding: 26px;
    box-shadow: 0 18px 50px rgba(0,0,0,0.18);
    transform: translateY(8px) scale(0.985);
    transition: transform 0.18s ease;
  }

  .note-preview-modal.open .note-preview-card {
    transform: translateY(0) scale(1);
  }

  .note-preview-close {
    position: absolute;
    top: 12px;
    right: 16px;
    border: none;
    background: transparent;
    font-size: 30px;
    line-height: 1;
    cursor: pointer;
    color: #666;
  }

  .note-preview-title {
    margin: 0 0 8px 0;
  }

  .note-preview-date {
    color: #777;
    margin-bottom: 18px;
    font-size: 14px;
  }

  .note-preview-body {
    border: 1px solid #ececec;
    border-radius: 14px;
    background: #fcfcfc;
    padding: 18px;
    min-height: 120px;
    line-height: 1.55;
    overflow-wrap: break-word;
  }

  .note-preview-body p:last-child {
    margin-bottom: 0;
  }

  .note-preview-image-wrap {
    margin-top: 14px;
  }

  .note-preview-image {
    display: block;
    max-width: 100%;
    max-height: 380px;
    height: auto;
    border-radius: 10px;
  }

  .note-preview-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 20px;
  }
</style>

<div class="notes-topbar">
  <h1>Notes</h1>
  <a href="/" class="btn btn-outline-secondary rounded-pill px-3">Back to calendar</a>
</div>

<hr class="my-4">

<h2 class="notes-section-title">Add a note</h2>

<div class="note-form-card">
  <%= form_with url: "/insert_note", method: :post, scope: :note do |form| %>
    <% if @selected_date.present? %>
      <input type="hidden" name="query_date" value="<%= @selected_date %>">
      <p class="note-date mb-3">Date: <%= @selected_date %></p>
    <% end %>

    <div class="note-editor">
      <label class="fw-semibold mb-2 d-block">Note</label>
      <%= form.rich_text_area :content %>
    </div>

    <button type="submit" class="btn btn-dark rounded-3 px-4">Save note</button>
  <% end %>
</div>

<hr class="my-4">

<h2 class="notes-section-title">Your notes</h2>

<div class="notes-list">
  <% if @list_of_notes.any? %>
    <% @list_of_notes.each do |n| %>
      <% preview_text =
           if n.respond_to?(:content) && n.content.present?
             n.content.to_plain_text
           else
             n.body.to_s
           end %>

      <% preview_html =
           if n.respond_to?(:content) && n.content.present?
             simple_format(h(n.content.to_plain_text))
           else
             simple_format(h(n.body.to_s))
           end %>

      <% first_image_url = nil %>
      <% if n.respond_to?(:content) && n.content.present? %>
        <% attachment = n.content.body.attachments.find { |a| a.attachable.respond_to?(:image?) && a.attachable.image? } %>
        <% if attachment.present? %>
          <% first_image_url = url_for(attachment.attachable) %>
        <% end %>
      <% end %>

      <div
        class="note-row"
        data-note-id="<%= n.id %>"
        data-note-date="<%= n.date %>"
        data-note-url="/notes/<%= n.id %>"
        data-delete-url="/delete_note/<%= n.id %>"
        data-note-image-url="<%= first_image_url %>"
      >
        <div class="note-preview">
          <%= preview_text.truncate(80) %>
        </div>

        <% if n.date.present? %>
          <div class="note-date">
            <%= n.date %>
          </div>
        <% end %>

        <div class="note-hidden-content">
          <%= preview_html %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="notes-empty">
      No notes yet.
    </div>
  <% end %>
</div>

<div id="note-preview-modal" class="note-preview-modal">
  <div class="note-preview-card">
    <button type="button" id="note-preview-close" class="note-preview-close">&times;</button>

    <h2 class="note-preview-title">Note Preview</h2>
    <p id="note-preview-date" class="note-preview-date"></p>

    <div id="note-preview-body" class="note-preview-body"></div>

    <div class="note-preview-actions">
      <a id="note-preview-edit" href="#" class="btn btn-dark rounded-3 px-4">Update note</a>
      <a id="note-preview-delete" href="#" class="btn btn-outline-danger rounded-3 px-4">Delete note</a>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var modal = document.getElementById("note-preview-modal");
  var closeBtn = document.getElementById("note-preview-close");
  var bodyEl = document.getElementById("note-preview-body");
  var dateEl = document.getElementById("note-preview-date");
  var editEl = document.getElementById("note-preview-edit");
  var deleteEl = document.getElementById("note-preview-delete");

  function openModal(noteRow) {
    var hiddenContent = noteRow.querySelector(".note-hidden-content");
    var imageUrl = noteRow.dataset.noteImageUrl;

    bodyEl.innerHTML = hiddenContent ? hiddenContent.innerHTML : "";

    if (imageUrl) {
      var imageWrap = document.createElement("div");
      imageWrap.className = "note-preview-image-wrap";

      var img = document.createElement("img");
      img.className = "note-preview-image";
      img.src = imageUrl;
      img.alt = "Note image";

      imageWrap.appendChild(img);
      bodyEl.appendChild(imageWrap);
    }

    dateEl.textContent = noteRow.dataset.noteDate ? ("Date: " + noteRow.dataset.noteDate) : "";
    editEl.href = noteRow.dataset.noteUrl || "#";
    deleteEl.href = noteRow.dataset.deleteUrl || "#";

    modal.classList.add("open");
    document.body.style.overflow = "hidden";
  }

  function closeModal() {
    modal.classList.remove("open");
    document.body.style.overflow = "";

    setTimeout(function() {
      if (!modal.classList.contains("open")) {
        bodyEl.innerHTML = "";
      }
    }, 180);
  }

  document.querySelectorAll(".note-row").forEach(function(row) {
    row.addEventListener("click", function() {
      openModal(row);
    });
  });

  closeBtn.addEventListener("click", closeModal);

  modal.addEventListener("click", function(e) {
    if (e.target === modal) {
      closeModal();
    }
  });

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") {
      closeModal();
    }
  });
});
</script>
