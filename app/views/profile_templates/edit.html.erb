<div class="page-card">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2 mb-0">Your profile</h1>
    <a href="/" class="btn btn-outline-secondary">Back to calendar</a>
  </div>

  <div class="mb-4">
    <% if @the_user.avatar.attached? %>
      <%= image_tag url_for(@the_user.avatar),
            style: "width:96px; height:96px; border-radius:50%; object-fit:cover; border:1px solid #dee2e6;" %>
    <% else %>
      <div class="d-flex align-items-center justify-content-center"
           style="width:96px; height:96px; border-radius:50%; border:1px solid #dee2e6; background:#f8f9fa;">
        No photo
      </div>
    <% end %>
  </div>

  <form action="/profile" method="post" enctype="multipart/form-data">
    <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

    <div class="mb-3">
      <label for="name_box" class="form-label fw-semibold">Username</label>
      <input id="name_box"
             type="text"
             name="query_name"
             value="<%= @the_user.name %>"
             class="form-control">
    </div>

    <div class="mb-4">
      <label for="avatar_box" class="form-label fw-semibold">Profile picture</label>
      <input id="avatar_box"
             type="file"
             name="query_avatar"
             class="form-control">
    </div>

    <button type="submit" class="btn btn-dark px-4">Save profile</button>
  </form>
</div>
