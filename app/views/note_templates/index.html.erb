<h1>Notes</h1>

<div style="margin: 10px 0;">
  <a href="/">Back to calendar</a>
</div>

<hr>

<h2>Add a note</h2>

<form action="/insert_note" method="post">
  <%# Optional: if you're on /notes?date=YYYY-MM-DD this will use that date %>
  <% if @selected_date.present? %>
    <input type="hidden" name="query_date" value="<%= @selected_date %>">
    <p>Date: <%= @selected_date %></p>
  <% end %>

  <div>
    <label for="body_box">Note</label><br>
    <textarea id="body_box" name="query_body" rows="6" style="width: 100%; max-width: 700px;"></textarea>
  </div>

  <button type="submit">Save note</button>
</form>

<ul>
  <% @list_of_notes.each do |n| %>
    <li>
      <a href="/notes/<%= n.id %>">
        <%= n.body.to_s.truncate(60) %>
      </a>
      <% if n.date.present? %>
        <span style="color:#777;">(<%= n.date %>)</span>
      <% end %>
    </li>
  <% end %>
</ul>
