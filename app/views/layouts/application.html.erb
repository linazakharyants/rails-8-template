<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails 8 Template" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

    <div style="max-width:1200px; margin:0 auto; padding:10px 0; display:flex; justify-content:flex-end; align-items:center; gap:12px;">

  <% if user_signed_in? %>

    <div style="display:flex; align-items:center; gap:10px;">

      <% if current_user.avatar.present? %>
        <img src="<%= current_user.avatar %>"
             style="width:34px; height:34px; border-radius:50%; object-fit:cover;">
      <% else %>
        <div style="width:34px; height:34px; border-radius:50%; background:#ddd;"></div>
      <% end %>

      <span style="font-size:14px;">
        <%= current_user.name || current_user.email %>
      </span>

      <%= link_to "Logout", destroy_user_session_path, method: :delete %>

    </div>

  <% else %>

    <div style="font-size:14px;">
      <%= link_to "Login", new_user_session_path %> |
      <%= link_to "Sign up", new_user_registration_path %>
    </div>

  <% end %>

</div>

    <%= yield %>

  </body>
</html>
