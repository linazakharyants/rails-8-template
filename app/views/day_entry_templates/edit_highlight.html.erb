<div class="page-card">
  <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <h1 class="mb-0">
      <% if @the_day_entry.highlight_of_the_day.present? %>
        Update highlight
      <% else %>
        Add highlight
      <% end %>
    </h1>

    <div class="d-flex gap-2 flex-wrap">
      <a href="/" class="btn btn-outline-secondary rounded-pill px-3">Back to calendar</a>
      <a href="/day_entries" class="btn btn-outline-secondary rounded-pill px-3">All day entries</a>
    </div>
  </div>

  <div class="mb-4">
    <p class="text-muted mb-0"><strong>Date:</strong> <%= @the_day_entry.date %></p>
  </div>

  <hr class="my-4">

  <div>
    <h2 class="h4 mb-3">Highlight of the day</h2>

    <form action="/upsert_highlight/<%= @date %>" method="post">
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div class="mb-3" style="max-width: 460px;">
        <label for="highlight_box" class="form-label fw-semibold">Highlight</label>
        <input
          type="text"
          id="highlight_box"
          name="query_highlight_of_the_day"
          value="<%= @the_day_entry.highlight_of_the_day %>"
          class="form-control"
        >
      </div>

      <button type="submit" class="btn btn-dark rounded-3 px-4">
        <% if @the_day_entry.highlight_of_the_day.present? %>
          Update highlight
        <% else %>
          Save highlight
        <% end %>
      </button>
    </form>
  </div>
</div>
