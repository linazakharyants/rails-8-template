<div class="mx-auto" style="max-width: 560px;">
  <div class="bg-white rounded-4 shadow-sm border" style="padding: 40px 36px;">
    <h2 class="mb-4 fw-semibold text-center" style="font-size: 2.1rem;">Log in</h2>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="form-inputs">
        <%= f.input :email,
                    required: false,
                    autofocus: true,
                    label: "Email",
                    input_html: {
                      autocomplete: "email",
                      class: "form-control rounded-3",
                      style: "padding: 14px 16px; font-size: 1rem;"
                    },
                    label_html: { class: "form-label fw-semibold mb-2" },
                    wrapper_html: { class: "mb-3" } %>

        <%= f.input :password,
                    required: false,
                    label: "Password",
                    input_html: {
                      autocomplete: "current-password",
                      class: "form-control rounded-3",
                      style: "padding: 14px 16px; font-size: 1rem;"
                    },
                    label_html: { class: "form-label fw-semibold mb-2" },
                    wrapper_html: { class: "mb-3" } %>

        <%= f.input :remember_me,
                    as: :boolean,
                    label: "Remember me",
                    wrapper_html: { class: "mb-4" },
                    input_html: { class: "form-check-input" },
                    label_html: { class: "form-check-label" } if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions d-grid mb-3">
        <%= f.button :submit, "Log in",
              class: "btn btn-dark rounded-3",
              style: "padding: 13px 16px; font-size: 1.05rem;" %>
      </div>
    <% end %>

    <div class="text-center" style="line-height: 1.8;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
