<style>
  .notes-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    flex-wrap: wrap;
    gap: 10px;
  }

  .notes-topbar h1 {
    margin: 0;
  }

  .notes-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 12px;
  }

  .note-row {
    display: block;
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid #ddd;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: all 0.15s ease;
  }

  .note-row:hover {
    background: #f8f7ff;
    border-color: #dcd7ff;
    transform: translateY(-1px);
  }

  .note-preview {
    font-size: 14px;
    line-height: 1.4;
  }

  .note-date {
    font-size: 12px;
    color: #888;
    margin-top: 4px;
  }

  .note-editor {
    margin-top: 12px;
    margin-bottom: 14px;
  }

  .note-editor trix-editor {
    min-height: 220px;
    border-radius: 10px;
    border: 1px solid #ddd;
    background: #fff;
    padding: 10px 12px;
  }

  .notes-section-title {
    margin-bottom: 12px;
  }

  .note-form-card {
    background: #fff;
    border: 1px solid #ddd;
    border-radius: 14px;
    padding: 18px;
    margin-bottom: 22px;
  }

  .notes-empty {
    padding: 16px;
    border: 1px dashed #d8d8d8;
    border-radius: 12px;
    background: #fcfcfc;
    color: #777;
    font-size: 14px;
  }
</style>

<div class="notes-topbar">
  <h1>Notes</h1>
  <a href="/" class="btn btn-outline-secondary rounded-pill px-3">Back to calendar</a>
</div>

<hr class="my-4">

<h2 class="notes-section-title">Add a note</h2>

<%= form_with url: "/insert_note", method: :post, scope: :note do |form| %>
  <% if @selected_date.present? %>
    <input type="hidden" name="query_date" value="<%= @selected_date %>">
    <p class="note-date mb-3">Date: <%= @selected_date %></p>
  <% end %>

  <div class="note-editor">
    <label class="fw-semibold mb-2 d-block">Note</label>
    <%= form.rich_text_area :content %>
  </div>

  <button type="submit" class="btn btn-dark rounded-3 px-4">Save note</button>
<% end %>

<hr class="my-4">

<h2 class="notes-section-title">Your notes</h2>

<div class="notes-list">
  <% if @list_of_notes.any? %>
    <% @list_of_notes.each do |n| %>
      <% preview_text =
           if n.respond_to?(:content) && n.content.present?
             n.content.to_plain_text
           else
             n.body.to_s
           end %>

      <a href="/notes/<%= n.id %>" class="note-row">
        <div class="note-preview">
          <%= preview_text.truncate(80) %>
        </div>

        <% if n.date.present? %>
          <div class="note-date">
            <%= n.date %>
          </div>
        <% end %>
      </a>
    <% end %>
  <% else %>
    <div class="notes-empty">
      No notes yet.
    </div>
  <% end %>
</div>
