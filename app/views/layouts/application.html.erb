<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Rails 8 Template" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>

<div style="display:flex; justify-content:flex-end; align-items:center; gap:10px; padding:12px 16px;">
  <% if user_signed_in? %>

    <a href="/profile" style="display:flex; align-items:center; gap:10px; text-decoration:none; color:inherit;">
      <% if current_user.avatar.present? %>
        <img src="<%= current_user.avatar %>"
             style="width:40px; height:40px; border-radius:50%; object-fit:cover; border:1px solid #ddd;">
      <% else %>
        <div style="width:40px; height:40px; border-radius:50%; border:1px solid #ddd; display:flex; align-items:center; justify-content:center;">
          <%= (current_user.name.presence || current_user.email).to_s.first.upcase %>
        </div>
      <% end %>

      <strong><%= current_user.name.presence || "User" %></strong>
    </a>

    <%= button_to "Log out", destroy_user_session_path, method: :delete,
          style: "border:1px solid #ddd; padding:8px 14px; border-radius:12px; background:white; cursor:pointer;" %>

  <% else %>
    <div style="display:flex; gap:10px;">
      <a href="<%= new_user_session_path %>">Log in</a>
      <a href="<%= new_user_registration_path %>">Sign up</a>
    </div>
  <% end %>
</div>

<%= yield %>

  </body>
</html>
