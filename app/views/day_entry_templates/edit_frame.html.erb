<h1>Frame of the Day</h1>

<article>
  <div>
    <a href="/">Back to calendar</a>
  </div>

  <div>
    <a href="/day_entries/<%= @the_day_entry.id %>">Back to entry</a>
  </div>

  <div>
    <a href="/delete_day_entry/<%= @the_day_entry.id %>">Delete day entry</a>
  </div>

  <dl>
    <dt>Date</dt>
    <dd><%= @the_day_entry.date %></dd>

    <dt>Current frame</dt>
    <dd>
      <% if @the_day_entry.photo.attached? %>
        <%= image_tag url_for(@the_day_entry.photo), style: "max-width:300px; border-radius:10px;" %>
      <% else %>
        No frame yet
      <% end %>
    </dd>
  </dl>
</article>

<hr>

<article>
  <header>
    <h2>
      <% if @the_day_entry.photo.attached? %>
        Update frame
      <% else %>
        Add frame
      <% end %>
    </h2>
  </header>

  <form action="/modify_day_entry_frame/<%= @the_day_entry.id %>" method="post" enctype="multipart/form-data">
    <div>
      <label for="photo_box">Upload a new frame</label>
      <input id="photo_box" type="file" name="query_photo">
    </div>

    <button type="submit">
      <% if @the_day_entry.photo.attached? %>
        Update frame
      <% else %>
        Save frame
      <% end %>
    </button>
  </form>
</article>


