<h1>
  <% if @the_day_entry.highlight_of_the_day.present? %>
    Update highlight
  <% else %>
    Add highlight
  <% end %>
</h1>

<article>
  <div>
    <a href="/">Back to calendar</a>
  </div>

  <div>
    <a href="/day_entries">All day entries</a>
  </div>

  <dl>
    <dt>Date</dt>
    <dd><%= @the_day_entry.date %></dd>
  </dl>
</article>

<hr>

<article>
  <header>
    <h2>Highlight of the day</h2>
  </header>

  <form action="/modify_day_entry_highlight/<%= @the_day_entry.date %>" method="post">
    <div>
      <label for="highlight_box">Highlight</label>
      <input
        type="text"
        id="highlight_box"
        name="query_highlight_of_the_day"
        value="<%= @the_day_entry.highlight_of_the_day %>"
        style="width: 360px;"
      >
    </div>

    <button type="submit">
      <% if @the_day_entry.highlight_of_the_day.present? %>
        Update highlight
      <% else %>
        Save highlight
      <% end %>
    </button>
  </form>
</article>

