<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

<h1 style="margin: 16px 0;">Calendar</h1>

<div id="calendar" style="max-width: 1100px;"></div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    var calendarEl = document.getElementById("calendar");

    var calendar = new FullCalendar.Calendar(calendarEl, {
      initialView: "dayGridMonth",
      events: "/day_entries.json",

      // click an existing entry on the calendar -> go to its show page
      eventClick: function(info) {
        window.location.href = "/day_entries/" + info.event.id;
      },

      // click an empty day -> go to the DayEntries page with date prefilled
      dateClick: function(info) {
        window.location.href = "/day_entries?date=" + info.dateStr;
      }
    });

    calendar.render();
  });
</script>
