<style>
.notes-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 12px;
}

.note-row {
  display: block;
  padding: 12px 14px;
  border-radius: 12px;
  border: 1px solid #ddd;
  background: #fff;

  text-decoration: none;
  color: inherit;

  transition: all 0.15s ease;
}

.note-row:hover {
  background: #f8f7ff;
  border-color: #dcd7ff;
}

.note-preview {
  font-size: 14px;
  line-height: 1.4;
}

.note-date {
  font-size: 12px;
  color: #888;
  margin-top: 4px;
}

.note-editor {
  margin-top: 12px;
  margin-bottom: 14px;
}

.note-editor trix-editor {
  min-height: 220px;
  border-radius: 10px;
}

.notes-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.back-link {
  text-decoration: none;
  font-size: 14px;
}
</style>


<h1>Notes</h1>

<div class="notes-header">
  <a href="/" class="back-link">← Back to calendar</a>
</div>

<hr>

<h2>Add a note</h2>

<form action="/insert_note" method="post">
  <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

  <% if @selected_date.present? %>
    <input type="hidden" name="query_date" value="<%= @selected_date %>">
    <p class="note-date">Date: <%= @selected_date %></p>
  <% end %>

  <div class="note-editor">
    <label for="content_box"><strong>Note</strong></label><br>

    <trix-editor input="query_content"></trix-editor>
    <input id="query_content" type="hidden" name="query_content">
  </div>

  <button type="submit">Save note</button>
</form>

<hr>

<h2>Your notes</h2>

<div class="notes-list">
  <% @list_of_notes.each do |n| %>
    <% preview_text =
         if n.respond_to?(:content) && n.content.present?
           n.content.to_plain_text
         else
           n.body.to_s
         end %>

    <a href="/notes/<%= n.id %>" class="note-row">
      <div class="note-preview">
        <%= preview_text.truncate(80) %>
      </div>

      <% if n.date.present? %>
        <div class="note-date">
          <%= n.date %>
        </div>
      <% end %>
    </a>

  <% end %>
</div>
