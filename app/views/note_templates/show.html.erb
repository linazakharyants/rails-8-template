<h1>Note</h1>

<div style="margin: 10px 0;">
  <a href="/notes">Back to notes</a>
</div>

<p><strong>Date:</strong> <%= @the_note.date %></p>

<hr>

<h2>Edit note</h2>

<form action="/modify_note/<%= @the_note.id %>" method="post">
  <div>
    <textarea name="query_body" rows="10" style="width: 100%; max-width: 700px;"><%= @the_note.body %></textarea>
  </div>

  <button type="submit">Update note</button>
</form>

<div style="margin-top: 10px;">
  <a href="/delete_note/<%= @the_note.id %>">Delete note</a>
</div>
