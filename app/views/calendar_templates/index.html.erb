<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css">
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

<style>
  .page-wrap {
    display: flex;
    gap: 18px;
    align-items: stretch;
    max-width: 1200px;
  }

  .calendar-col {
    flex: 1;
    min-width: 0;
  }

  .notes-col {
    width: 170px;
    display: flex;
  }

  .notes-card {
    height: 100%;
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 14px 14px 10px 14px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    display: block;
    box-sizing: border-box;
  }

  .notes-title {
    font-weight: 700;
    font-size: 16px;
    margin-bottom: 10px;
  }

  .notebook-lines {
    border-radius: 10px;
    padding: 10px 10px;
    background:
      linear-gradient(#ffffff, #ffffff) padding-box,
      repeating-linear-gradient(
        to bottom,
        rgba(0,0,0,0.08),
        rgba(0,0,0,0.08) 1px,
        transparent 1px,
        transparent 22px
      );
    min-height: 320px;
  }

  .notes-hint {
    font-size: 12px;
    color: #666;
    margin-top: 10px;
  }

  .top-banner {
    width: 100%;
    padding: 12px 14px;
    margin: 10px 0 14px 0;
    border: 1px solid #ddd;
    border-radius: 12px;
    font-size: 14px;
    box-sizing: border-box;
  }

  /* Highlight box styling */
  .highlight-pill {
    font-size: 12px;
    font-weight: 600;
    line-height: 1.25;
    padding: 4px 6px;
    border-radius: 6px;
    background: #ffd6e7;
    color: #7a0f3b;

    white-space: normal;
    word-break: break-word;
    overflow: hidden;

    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
  }

  @media (max-width: 1000px) {
    .page-wrap { flex-direction: column; }
    .notes-col { width: 100%; }
    .notebook-lines { min-height: 180px; }
  }
</style>

<h1>Calendar</h1>

<div class="page-wrap">

  <div class="calendar-col">

    <div class="top-banner">
      <a href="/highlights/<%= Date.today %>" style="text-decoration:none; color:inherit;">
        <strong>Line of the day</strong>
      </a>
    </div>

    <div class="top-banner">
      <a href="/habits" style="text-decoration:none; color:inherit;">
        <strong>Habit Tracker</strong>
      </a>
    </div>

    <div id="calendar"></div>

  </div>

  <div class="notes-col">
    <a class="notes-card" href="/notes">
      <div class="notes-title">Notes</div>
      <div class="notebook-lines"></div>
      <div class="notes-hint">Open notebook →</div>
    </a>
  </div>

</div>

<script>
document.addEventListener("DOMContentLoaded", function() {

  function escapeHtml(str) {
    return String(str || "")
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");
  }

  var calendarElement = document.getElementById("calendar");

  var calendar = new FullCalendar.Calendar(calendarElement, {

    initialView: "dayGridMonth",

    events: "/calendar.json",

    eventContent: function(info) {

      var title = info.event.title || "";

      return {
        html:
          "<div class='highlight-pill'>" +
          escapeHtml(title) +
          "</div>"
      };
    },

    eventDidMount: function(info) {

      var dayCell = info.el.closest(".fc-daygrid-day");
      if (!dayCell) return;

      var pct = info.event.extendedProps.habit_percent;

      if (pct !== null && pct !== undefined && !dayCell.querySelector(".habit-percent")) {

        var pctDiv = document.createElement("div");
        pctDiv.className = "habit-percent";
        pctDiv.innerText = "Habits: " + pct + "%";
        pctDiv.style.marginTop = "4px";
        pctDiv.style.fontSize = "12px";
        pctDiv.style.color = "#555";

        var frameArea = dayCell.querySelector(".fc-daygrid-day-frame");
        if (frameArea) frameArea.appendChild(pctDiv);
      }

      var photo = info.event.extendedProps.photo;
      if (!photo) return;

      if (dayCell.querySelector(".frame-link")) return;

      var link = document.createElement("a");
      link.href = "/frames/" + info.event.id;
      link.innerText = "Frame of the Day";
      link.className = "frame-link";

      link.style.display = "block";
      link.style.marginTop = "4px";
      link.style.fontSize = "12px";

      link.addEventListener("click", function(e) {
        e.preventDefault();
        e.stopPropagation();
        window.location.href = link.href;
      });

      var frame = dayCell.querySelector(".fc-daygrid-day-frame");
      if (frame) frame.appendChild(link);
    },

    eventClick: function(info) {
      info.jsEvent.preventDefault();
      info.jsEvent.stopPropagation();
      window.location.href = "/highlights/" + info.event.startStr;
    }

  });

  calendar.render();

});
</script>
