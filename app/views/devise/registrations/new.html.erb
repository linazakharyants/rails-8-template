<div class="mx-auto" style="max-width: 560px;">
  <div class="bg-white rounded-4 shadow-sm border" style="padding: 40px 36px;">
    <h2 class="mb-4 fw-semibold text-center" style="font-size: 2.1rem;">Sign up</h2>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: "Email",
                    input_html: {
                      autocomplete: "email",
                      class: "form-control rounded-3",
                      style: "padding: 14px 16px; font-size: 1rem;"
                    },
                    label_html: { class: "form-label fw-semibold mb-2" },
                    wrapper_html: { class: "mb-3" } %>

        <%= f.input :password,
                    required: true,
                    label: "Password",
                    hint: ("#{@minimum_password_length} characters minimum" if @minimum_password_length),
                    input_html: {
                      autocomplete: "new-password",
                      class: "form-control rounded-3",
                      style: "padding: 14px 16px; font-size: 1rem;"
                    },
                    label_html: { class: "form-label fw-semibold mb-2" },
                    wrapper_html: { class: "mb-3" } %>

        <%= f.input :password_confirmation,
                    required: true,
                    label: "Confirm password",
                    input_html: {
                      autocomplete: "new-password",
                      class: "form-control rounded-3",
                      style: "padding: 14px 16px; font-size: 1rem;"
                    },
                    label_html: { class: "form-label fw-semibold mb-2" },
                    wrapper_html: { class: "mb-4" } %>
      </div>

      <div class="form-actions d-grid mb-3">
        <%= f.button :submit, "Sign up",
              class: "btn btn-dark rounded-3",
              style: "padding: 13px 16px; font-size: 1.05rem;" %>
      </div>
    <% end %>

    <div class="text-center" style="line-height: 1.8;">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
