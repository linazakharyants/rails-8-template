<div style="margin: 10px 0;">
  <a href="/habits_manage" class="manage-link">Add / Update Habits</a>
</div>

<style>
.manage-link {
  display: inline-block;
  font-size: 12px;
  margin-top: 4px;
}
</style>

  <ul>
    <% @list_of_habits.each do |a_habit| %>
      <li>
        <a href="/habits/<%= a_habit.id %>">
          <%= a_habit.name %>
        </a>

        <% if a_habit.description.present? %>
          — <%= a_habit.description %>
        <% end %>
      </li>
    <% end %>
  </ul>
</article>

<hr>
